generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AnalyticsScope {
  COURSE
  PLATFORM
}

enum VideoProvider {
  EXTERNAL
  R2
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
}

enum OrganizationRole {
  OWNER
  ADMIN
  INSTRUCTOR
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PortalStatus {
  DRAFT
  PUBLISHED
}

enum PortalPageType {
  HOME
  CATALOG
  COURSE_TEMPLATE
  AFTER_LOGIN
  CUSTOM
}

enum PortalBlockType {
  HERO
  FEATURED_COURSES
  COURSE_CATALOG
  RICH_TEXT
  IMAGE_TEXT
  INSTRUCTOR_PROFILE
  TESTIMONIALS
  FAQ
  CTA
  PRICING
  LOGIN_SIGNUP
  RESUME_LEARNING
  REQUIRED_WORK
  COURSE_COLLECTION
}

model User {
  id                      String                   @id @default(cuid())
  clerkId                 String                   @unique
  email                   String                   @unique
  name                    String?
  imageUrl                String?
  stripeCustomerId        String?                  @unique
  role                    Role                     @default(STUDENT)
  bio                     String?
  websiteUrl              String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  courses                 Course[]                 @relation("CourseInstructor")
  enrollments             Enrollment[]
  lessonProgress          LessonProgress[]
  payments                Payment[]
  assessmentSubmissions   AssessmentSubmission[]
  certificates            Certificate[]
  organizationMemberships OrganizationMembership[]
  sentInvitations         OrganizationInvitation[] @relation("InvitationInviter")

  @@index([role])
}

model Course {
  id                  String            @id @default(cuid())
  instructorId        String
  title               String
  slug                String            @unique
  subtitle            String?
  description         String?
  thumbnailUrl        String?
  priceCents          Int               @default(0)
  currency            String            @default("usd")
  status              CourseStatus      @default(DRAFT)
  certificatesEnabled Boolean           @default(true)
  level               String            @default("Beginner")
  durationMinutes     Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  publishedAt         DateTime?
  instructor          User              @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  organizationId      String?
  organization        Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sections            CourseSection[]
  enrollments         Enrollment[]
  payments            Payment[]
  analyticsRollups    AnalyticsRollup[]
  assessments         Assessment[]
  certificates        Certificate[]

  @@index([instructorId, status])
  @@index([organizationId, status])
}

model Organization {
  id           String                   @id @default(cuid())
  clerkOrgId   String?                  @unique
  name         String
  slug         String                   @unique
  supportEmail String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  memberships  OrganizationMembership[]
  invitations  OrganizationInvitation[]
  courses      Course[]
  portal       OrganizationPortal?
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           OrganizationRole @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email, status])
}

model OrganizationPortal {
  id             String       @id @default(cuid())
  organizationId String       @unique
  status         PortalStatus @default(DRAFT)
  logoUrl        String?
  primaryColor   String       @default("#1e3a8a")
  accentColor    String       @default("#0f766e")
  fontFamily     String       @default("sans")
  buttonStyle    String       @default("rounded")
  navLinks       Json?
  footerLinks    Json?
  publishedTheme Json?
  customDomain   String?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages          PortalPage[]

  @@index([status])
}

model PortalPage {
  id                      String             @id @default(cuid())
  portalId                String
  type                    PortalPageType
  slug                    String
  title                   String
  seoTitle                String?
  seoDescription          String?
  status                  PortalStatus       @default(DRAFT)
  publishedTitle          String?
  publishedSeoTitle       String?
  publishedSeoDescription String?
  publishedAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  portal                  OrganizationPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  blocks                  PortalBlock[]

  @@unique([portalId, type])
  @@unique([portalId, slug])
  @@index([type, status])
}

model PortalBlock {
  id              String          @id @default(cuid())
  pageId          String
  type            PortalBlockType
  position        Int             @default(0)
  config          Json
  publishedConfig Json?
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  page            PortalPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, position])
  @@index([type])
}

model CourseSection {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id              String           @id @default(cuid())
  sectionId       String
  title           String
  slug            String
  content         String?
  videoUrl        String?
  videoProvider   VideoProvider?
  videoAssetKey   String?
  videoMimeType   String?
  videoBytes      Int?
  durationMinutes Int              @default(0)
  preview         Boolean          @default(false)
  position        Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  section         CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources       LessonResource[]
  progress        LessonProgress[]

  @@unique([sectionId, slug])
}

model LessonResource {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  fileUrl   String
  fileKey   String?
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([status, createdAt])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime?
  lastSeenAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId, completedAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  courseId        String
  stripeSessionId String?       @unique
  stripePaymentId String?
  amountCents     Int
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  rawEvent        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, status, createdAt])
}

model AnalyticsRollup {
  id                   String         @id @default(cuid())
  scope                AnalyticsScope
  courseId             String?
  date                 DateTime
  activeEnrollments    Int            @default(0)
  completedEnrollments Int            @default(0)
  lessonCompletions    Int            @default(0)
  revenueCents         Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  course               Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([scope, courseId, date])
  @@index([scope, date])
  @@index([courseId, date])
}

model Assessment {
  id                    String                 @id @default(cuid())
  courseId              String
  title                 String
  description           String?
  type                  AssessmentType         @default(QUIZ)
  passingScore          Int                    @default(70)
  requiredForCompletion Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions             AssessmentQuestion[]
  submissions           AssessmentSubmission[]

  @@index([courseId, requiredForCompletion])
}

model AssessmentQuestion {
  id           String     @id @default(cuid())
  assessmentId String
  prompt       String
  options      Json
  correctIndex Int
  position     Int        @default(0)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentSubmission {
  id           String     @id @default(cuid())
  assessmentId String
  userId       String
  answers      Json
  score        Int
  passed       Boolean
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, passed])
  @@index([assessmentId, userId])
}

model Certificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  userId            String
  courseId          String
  issuedAt          DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, issuedAt])
}
