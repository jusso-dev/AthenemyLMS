generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AnalyticsScope {
  COURSE
  PLATFORM
}

enum VideoProvider {
  EXTERNAL
  R2
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
  SURVEY
}

enum AssessmentQuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  LONG_ANSWER
}

enum AssessmentFeedbackMode {
  IMMEDIATE
  AFTER_PASSING
  AFTER_CLOSE
  HIDDEN
}

enum OrganizationRole {
  OWNER
  ADMIN
  INSTRUCTOR
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PortalStatus {
  DRAFT
  PUBLISHED
}

enum PortalPageType {
  HOME
  CATALOG
  COURSE_TEMPLATE
  AFTER_LOGIN
  CUSTOM
}

enum PortalBlockType {
  HERO
  FEATURED_COURSES
  COURSE_CATALOG
  RICH_TEXT
  IMAGE
  IMAGE_TEXT
  GALLERY
  INSTRUCTOR_PROFILE
  TESTIMONIALS
  FAQ
  CTA
  PRICING
  LOGIN_SIGNUP
  RESUME_LEARNING
  REQUIRED_WORK
  COURSE_COLLECTION
}

enum OrganizationAssetKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ExternalPackageType {
  SCORM_12
  XAPI
  LTI
}

enum ExternalPackageStatus {
  READY
  INVALID
  DISABLED
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum CohortStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DiscussionPostStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum LiveSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CouponDiscountType {
  PERCENT
  AMOUNT
}

model User {
  id                      String                   @id @default(cuid())
  clerkId                 String                   @unique
  email                   String                   @unique
  name                    String?
  imageUrl                String?
  stripeCustomerId        String?                  @unique
  role                    Role                     @default(STUDENT)
  bio                     String?
  websiteUrl              String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  courses                 Course[]                 @relation("CourseInstructor")
  enrollments             Enrollment[]
  lessonProgress          LessonProgress[]
  payments                Payment[]
  assessmentSubmissions   AssessmentSubmission[]
  certificates            Certificate[]
  organizationMemberships OrganizationMembership[]
  sentInvitations         OrganizationInvitation[] @relation("InvitationInviter")
  uploadedAssets          OrganizationAsset[]      @relation("AssetUploader")
  uploadedPackages        ExternalPackage[]        @relation("PackageUploader")
  externalAttempts        ExternalPackageAttempt[]
  apiKeys                 ApiKey[]                 @relation("ApiKeyCreator")
  auditLogs               AuditLog[]               @relation("AuditActor")
  automationRules         AutomationRule[]         @relation("AutomationRuleCreator")
  discussionPosts         DiscussionPost[]
  cohortMemberships       CohortMembership[]
  liveSessions            LiveSession[]            @relation("LiveSessionInstructor")

  @@index([role])
}

model Course {
  id                      String                   @id @default(cuid())
  instructorId            String
  title                   String
  slug                    String                   @unique
  subtitle                String?
  description             String?
  thumbnailUrl            String?
  priceCents              Int                      @default(0)
  currency                String                   @default("usd")
  status                  CourseStatus             @default(DRAFT)
  certificatesEnabled     Boolean                  @default(true)
  level                   String                   @default("Beginner")
  durationMinutes         Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  publishedAt             DateTime?
  archivedAt              DateTime?
  archivedById            String?
  sourceTemplateId        String?
  sourceTemplateVersion   Int?
  templateCategory        String?
  requiredForMembers      Boolean                  @default(false)
  autoEnrollMembers       Boolean                  @default(false)
  autoEnrollFutureMembers Boolean                  @default(false)
  instructor              User                     @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  organizationId          String?
  organization            Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sourceTemplate          CourseTemplate?          @relation("CourseTemplateInstances", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  sections                CourseSection[]
  enrollments             Enrollment[]
  payments                Payment[]
  analyticsRollups        AnalyticsRollup[]
  assessments             Assessment[]
  questionBanks           QuestionBank[]
  certificates            Certificate[]
  lifecycleEvents         CourseLifecycleEvent[]
  externalPackages        ExternalPackage[]
  externalAttempts        ExternalPackageAttempt[]
  learningEvents          LearningEvent[]
  cohorts                 Cohort[]
  discussions             DiscussionThread[]
  liveSessions            LiveSession[]
  bundles                 CourseBundleItem[]

  @@index([instructorId, status])
  @@index([organizationId, status])
  @@index([organizationId, requiredForMembers])
  @@index([sourceTemplateId])
}

model CourseTemplate {
  id                       String   @id
  category                 String
  title                    String
  slug                     String   @unique
  summary                  String
  lessons                  Json
  assessment               Json?
  certificatesEnabled      Boolean  @default(true)
  suggestedDurationMinutes Int      @default(0)
  version                  Int      @default(1)
  locale                   String   @default("en")
  tags                     String[] @default([])
  requiredSuggestion       Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  courses                  Course[] @relation("CourseTemplateInstances")

  @@index([category, locale])
}

model CourseLifecycleEvent {
  id         String        @id @default(cuid())
  courseId   String?
  actorId    String
  action     String
  fromStatus CourseStatus?
  toStatus   CourseStatus?
  metadata   Json?
  createdAt  DateTime      @default(now())
  course     Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([courseId, createdAt])
  @@index([actorId, createdAt])
}

model Organization {
  id                     String                       @id @default(cuid())
  clerkOrgId             String?                      @unique
  name                   String
  slug                   String                       @unique
  supportEmail           String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  memberships            OrganizationMembership[]
  invitations            OrganizationInvitation[]
  courses                Course[]
  portal                 OrganizationPortal?
  assets                 OrganizationAsset[]
  packages               ExternalPackage[]
  questionBanks          QuestionBank[]
  apiKeys                ApiKey[]
  webhookEndpoints       WebhookEndpoint[]
  learningEvents         LearningEvent[]
  automationRules        AutomationRule[]
  automationRuns         AutomationRun[]
  notificationDeliveries NotificationDelivery[]
  auditLogs              AuditLog[]
  customRoles            CustomOrganizationRole[]
  privacySettings        OrganizationPrivacySettings?
  bundles                CourseBundle[]
  coupons                CommerceCoupon[]
  cohorts                Cohort[]
  discussionThreads      DiscussionThread[]
  liveSessions           LiveSession[]
}

model OrganizationAsset {
  id             String                @id @default(cuid())
  organizationId String
  uploadedById   String
  kind           OrganizationAssetKind @default(IMAGE)
  storageKey     String
  url            String
  filename       String
  mimeType       String
  sizeBytes      Int?
  width          Int?
  height         Int?
  altText        String?
  caption        String?
  tags           String[]              @default([])
  usageNotes     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User                  @relation("AssetUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([organizationId, kind, createdAt])
  @@index([uploadedById, createdAt])
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           OrganizationRole @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email, status])
}

model OrganizationPortal {
  id             String       @id @default(cuid())
  organizationId String       @unique
  status         PortalStatus @default(DRAFT)
  logoUrl        String?
  primaryColor   String       @default("#071A3D")
  accentColor    String       @default("#D4AF37")
  fontFamily     String       @default("sans")
  buttonStyle    String       @default("rounded")
  themeMode      String       @default("system")
  navLinks       Json?
  footerLinks    Json?
  publishedTheme Json?
  customDomain   String?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages          PortalPage[]

  @@index([status])
}

model PortalPage {
  id                      String             @id @default(cuid())
  portalId                String
  type                    PortalPageType
  slug                    String
  title                   String
  seoTitle                String?
  seoDescription          String?
  status                  PortalStatus       @default(DRAFT)
  publishedTitle          String?
  publishedSeoTitle       String?
  publishedSeoDescription String?
  publishedAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  portal                  OrganizationPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  blocks                  PortalBlock[]

  @@unique([portalId, type])
  @@unique([portalId, slug])
  @@index([type, status])
}

model PortalBlock {
  id              String          @id @default(cuid())
  pageId          String
  type            PortalBlockType
  position        Int             @default(0)
  config          Json
  publishedConfig Json?
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  page            PortalPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, position])
  @@index([type])
}

model CourseSection {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id                String                   @id @default(cuid())
  sectionId         String
  title             String
  slug              String
  content           String?
  videoUrl          String?
  videoProvider     VideoProvider?
  videoAssetKey     String?
  videoMimeType     String?
  videoBytes        Int?
  durationMinutes   Int                      @default(0)
  preview           Boolean                  @default(false)
  position          Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  section           CourseSection            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources         LessonResource[]
  progress          LessonProgress[]
  externalPackages  ExternalPackage[]
  externalAttempts  ExternalPackageAttempt[]
  discussionThreads DiscussionThread[]

  @@unique([sectionId, slug])
}

model ExternalPackage {
  id             String                   @id @default(cuid())
  organizationId String?
  courseId       String
  lessonId       String?
  uploadedById   String
  type           ExternalPackageType
  status         ExternalPackageStatus    @default(READY)
  title          String
  identifier     String?
  version        String?
  storageKey     String?
  launchPath     String?
  launchUrl      String?
  manifest       Json?
  validationLog  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  course         Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson         Lesson?                  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  uploadedBy     User                     @relation("PackageUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  attempts       ExternalPackageAttempt[]

  @@index([courseId, type, status])
  @@index([lessonId, status])
  @@index([organizationId, type])
}

model ExternalPackageAttempt {
  id               String          @id @default(cuid())
  packageId        String
  userId           String
  courseId         String
  lessonId         String?
  completionStatus String          @default("unknown")
  successStatus    String?
  scoreScaled      Float?
  scoreRaw         Float?
  totalTimeSeconds Int             @default(0)
  suspendData      String?
  lastStatement    Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  package          ExternalPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson           Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@unique([packageId, userId])
  @@index([courseId, completionStatus])
  @@index([lessonId, completionStatus])
}

model LessonResource {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  fileUrl   String
  fileKey   String?
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([status, createdAt])
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyPrefix      String
  keyHash        String       @unique
  scopes         String[]     @default([])
  createdById    String?
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, revokedAt])
  @@index([keyPrefix])
}

model WebhookEndpoint {
  id             String            @id @default(cuid())
  organizationId String
  url            String
  secretHash     String
  eventTypes     String[]          @default([])
  active         Boolean           @default(true)
  createdById    String?
  lastDeliveryAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]

  @@index([organizationId, active])
}

model WebhookDelivery {
  id              String                @id @default(cuid())
  endpointId      String
  eventType       String
  payload         Json
  status          WebhookDeliveryStatus @default(PENDING)
  statusCode      Int?
  responseSummary String?
  attempts        Int                   @default(0)
  durationMs      Int?
  nextRetryAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  endpoint        WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([status, nextRetryAt])
}

model LearningEvent {
  id             String          @id @default(cuid())
  organizationId String?
  userId         String?
  courseId       String?
  type           String
  payload        Json
  idempotencyKey String?
  createdAt      DateTime        @default(now())
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  course         Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  runs           AutomationRun[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, type, createdAt])
  @@index([userId, createdAt])
  @@index([courseId, createdAt])
}

model AutomationRule {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  eventType      String
  actionType     String
  enabled        Boolean         @default(true)
  config         Json
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("AutomationRuleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  runs           AutomationRun[]

  @@index([organizationId, enabled, eventType])
}

model AutomationRun {
  id              String                 @id @default(cuid())
  organizationId  String
  ruleId          String?
  learningEventId String?
  status          AutomationRunStatus    @default(PENDING)
  triggerDevRunId String?
  error           String?
  metadata        Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rule            AutomationRule?        @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  learningEvent   LearningEvent?         @relation(fields: [learningEventId], references: [id], onDelete: SetNull)
  deliveries      NotificationDelivery[]

  @@index([organizationId, status, createdAt])
  @@index([ruleId, createdAt])
}

model NotificationDelivery {
  id              String                     @id @default(cuid())
  organizationId  String
  automationRunId String?
  channel         String
  recipient       String
  template        String
  status          NotificationDeliveryStatus @default(PENDING)
  error           String?
  metadata        Json?
  sentAt          DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationRun   AutomationRun?             @relation(fields: [automationRunId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  severity       AuditSeverity @default(INFO)
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor          User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

model CustomOrganizationRole {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  capabilities   String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

model OrganizationPrivacySettings {
  id                           String       @id @default(cuid())
  organizationId               String       @unique
  allowPublicCatalog           Boolean      @default(true)
  allowPublicCertificates      Boolean      @default(true)
  requireMfaForAdmins          Boolean      @default(false)
  dataRetentionDays            Int?
  exportTrainingRecordsEnabled Boolean      @default(true)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  organization                 Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CourseBundle {
  id             String             @id @default(cuid())
  organizationId String
  title          String
  slug           String
  description    String?
  priceCents     Int                @default(0)
  currency       String             @default("usd")
  status         CourseStatus       @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          CourseBundleItem[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

model CourseBundleItem {
  id       String       @id @default(cuid())
  bundleId String
  courseId String
  position Int          @default(0)
  bundle   CourseBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course   Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseId])
  @@index([courseId])
}

model CommerceCoupon {
  id              String             @id @default(cuid())
  organizationId  String
  code            String
  discountType    CouponDiscountType
  percentOff      Int?
  amountOffCents  Int?
  currency        String             @default("usd")
  active          Boolean            @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, active])
}

model Cohort {
  id             String             @id @default(cuid())
  organizationId String
  courseId       String
  name           String
  startsAt       DateTime?
  endsAt         DateTime?
  capacity       Int?
  status         CohortStatus       @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course         Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  memberships    CohortMembership[]
  threads        DiscussionThread[]

  @@index([organizationId, status])
  @@index([courseId, status])
}

model CohortMembership {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String
  createdAt DateTime @default(now())
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([userId])
}

model DiscussionThread {
  id             String           @id @default(cuid())
  organizationId String
  courseId       String
  lessonId       String?
  cohortId       String?
  title          String
  pinnedPostId   String?
  locked         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson         Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  cohort         Cohort?          @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  posts          DiscussionPost[]

  @@index([organizationId, createdAt])
  @@index([courseId, lessonId])
}

model DiscussionPost {
  id        String               @id @default(cuid())
  threadId  String
  authorId  String
  parentId  String?
  body      String
  status    DiscussionPostStatus @default(VISIBLE)
  isAnswer  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  thread    DiscussionThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
}

model LiveSession {
  id              String            @id @default(cuid())
  organizationId  String
  courseId        String
  cohortId        String?
  instructorId    String?
  title           String
  providerUrl     String
  startsAt        DateTime
  durationMinutes Int               @default(60)
  recordingUrl    String?
  status          LiveSessionStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor      User?             @relation("LiveSessionInstructor", fields: [instructorId], references: [id], onDelete: SetNull)

  @@index([organizationId, startsAt])
  @@index([courseId, startsAt])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime?
  lastSeenAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId, completedAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  courseId        String
  stripeSessionId String?       @unique
  stripePaymentId String?
  amountCents     Int
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  rawEvent        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, status, createdAt])
}

model AnalyticsRollup {
  id                   String         @id @default(cuid())
  scope                AnalyticsScope
  courseId             String?
  date                 DateTime
  activeEnrollments    Int            @default(0)
  completedEnrollments Int            @default(0)
  lessonCompletions    Int            @default(0)
  revenueCents         Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  course               Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([scope, courseId, date])
  @@index([scope, date])
  @@index([courseId, date])
}

model Assessment {
  id                    String                 @id @default(cuid())
  courseId              String
  questionBankId        String?
  title                 String
  description           String?
  type                  AssessmentType         @default(QUIZ)
  passingScore          Int                    @default(70)
  requiredForCompletion Boolean                @default(false)
  maxAttempts           Int?
  timeLimitMinutes      Int?
  feedbackMode          AssessmentFeedbackMode @default(IMMEDIATE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questionBank          QuestionBank?          @relation(fields: [questionBankId], references: [id], onDelete: SetNull)
  questions             AssessmentQuestion[]
  submissions           AssessmentSubmission[]
  rubricCriteria        RubricCriterion[]

  @@index([courseId, requiredForCompletion])
  @@index([questionBankId])
}

model AssessmentQuestion {
  id           String                 @id @default(cuid())
  assessmentId String
  type         AssessmentQuestionType @default(MULTIPLE_CHOICE)
  prompt       String
  options      Json
  correctIndex Int
  points       Int                    @default(1)
  position     Int                    @default(0)
  assessment   Assessment             @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentSubmission {
  id            String     @id @default(cuid())
  assessmentId  String
  userId        String
  attemptNumber Int        @default(1)
  answers       Json
  score         Int
  passed        Boolean
  feedback      String?
  gradedAt      DateTime?
  createdAt     DateTime   @default(now())
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, passed])
  @@index([assessmentId, userId])
}

model QuestionBank {
  id             String                 @id @default(cuid())
  organizationId String?
  courseId       String?
  title          String
  description    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course         Course?                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions      QuestionBankQuestion[]
  assessments    Assessment[]

  @@index([organizationId])
  @@index([courseId])
}

model QuestionBankQuestion {
  id             String                 @id @default(cuid())
  questionBankId String
  type           AssessmentQuestionType @default(MULTIPLE_CHOICE)
  prompt         String
  options        Json
  correctIndex   Int?
  points         Int                    @default(1)
  tags           String[]               @default([])
  explanation    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  questionBank   QuestionBank           @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@index([questionBankId, type])
}

model RubricCriterion {
  id           String     @id @default(cuid())
  assessmentId String
  title        String
  description  String?
  points       Int        @default(1)
  levels       Json?
  position     Int        @default(0)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, position])
}

model Certificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  userId            String
  courseId          String
  issuedAt          DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, issuedAt])
}
