# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
# Supabase pooled connection string for Prisma Client.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Supabase direct connection string for Prisma migrations.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_SECRET_KEY="sk_test_placeholder"
CLERK_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID="placeholder"
CLOUDFLARE_R2_ACCESS_KEY_ID="placeholder"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="placeholder"
CLOUDFLARE_R2_BUCKET_NAME="athenemy-dev"
CLOUDFLARE_R2_PUBLIC_BASE_URL="https://cdn.example.com"

# Email
EMAIL_PROVIDER="stub"
EMAIL_FROM="Athenemy <hello@example.com>"
RESEND_API_KEY="placeholder"
